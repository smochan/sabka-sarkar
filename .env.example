# Sabka Sarkar — environment variables
# The site works with ZERO env vars (concept mode: voting/comments disabled).
# Set variables below only when you are ready to go live.

# Public site URL (OG tags + share links). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://sabkasarkar.com

# --- Interactive features (voting, nominations, comments) ----------------
# Set to true only after TURSO_DATABASE_URL and TURSO_AUTH_TOKEN are set.
# Defaults to false — site runs in read-only concept mode without this.
# NEXT_PUBLIC_INTERACTIVE=true

# --- Database (libSQL / Turso) -------------------------------------------
# Not needed locally (auto-creates ./local.db).
# Required in production when NEXT_PUBLIC_INTERACTIVE=true.
# Create a free DB at turso.tech, then set:
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# --- Google sign-in (optional) -------------------------------------------
# When ALL of these are set, "Sign in with Google" appears.
# Create OAuth credentials at https://console.cloud.google.com
# AUTH_SECRET=run: npx auth secret
# AUTH_GOOGLE_ID=...apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=...
# NEXT_PUBLIC_AUTH_ENABLED=true

# --- Moderation ----------------------------------------------------------
# ADMIN_KEY=choose-a-long-secret
